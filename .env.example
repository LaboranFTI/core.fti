# Konfigurasi Database PostgreSQL
DB_USER=corefti
DB_PASSWORD=password_database_anda
DB_HOST=localhost
DB_NAME=dbcorefti
DB_PORT=5432
DB_SSL=false

# Konfigurasi Keamanan (JSON Web Token)
# # generate  di : https://www.lastpass.com/features/password-generator
JWT_SECRET=rahasia_jwt_super_aman_ganti_ini

# Konfigurasi Aplikasi Frontend (Vite)
VITE_API_BASE_URL=http://localhost:5000
VITE_PUBLIC_APP_URL=https://localhost:5173
FRONTEND_URL=https://localhost:5173
VITE_INSTITUTION_URL=https://fti.uksw.edu
PORT=5000
NODE_ENV=development

# Opsional: dipakai oleh konfigurasi Vite jika fitur Gemini/API key diaktifkan
GEMINI_API_KEY=

# Google Calendar API Credentials
# Dapatkan Client ID dan API Key dari Google Cloud Console
# Pastikan API Key dibatasi (HTTP Referrer Restriction) untuk domain production
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/auth/google/calendar/callback
VITE_GOOGLE_API_KEY=your-api-key-here
VITE_GOOGLE_CALENDAR_API_KEY=your-calendar-api-key-here

# reCAPTCHA
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ============================================================
# Konfigurasi Email (Nodemailer + Gmail App Password)
# ============================================================
# Langkah setup:
# 1. Login ke myaccount.google.com dengan akun Gmail pengirim
# 2. Security > 2-Step Verification (aktifkan dulu)
# 3. Security > App Passwords > buat password baru (nama: CORE FTI Mailer)
# 4. Salin 16 karakter tanpa spasi ke EMAIL_PASS
EMAIL_USER=noreply.core.fti@gmail.com
EMAIL_PASS=16_karakter_app_password_tanpa_spasi
EMAIL_FROM_NAME=TU FTI UKSW
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_TLS=true
EMAIL_HOSTNAME=smtp.gmail.com

# Alias SMTP legacy/kompatibilitas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply.core.fti@gmail.com
SMTP_PASS=16_karakter_app_password_tanpa_spasi
SENDER_NAME=TU FTI UKSW

# Integrasi SIASAT
SIASAT_SOAP_URL=https://example.ac.id/siasat/wsdl
SIASAT_SOAP_USER=username_siasat
SIASAT_SOAP_PASS=password_siasat
