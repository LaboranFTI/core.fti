# Konfigurasi Database PostgreSQL
DB_USER=corefti
DB_PASSWORD=password_database_anda
DB_HOST=localhost
DB_NAME=dbcorefti
DB_PORT=5432
DB_SSL=false

# Konfigurasi Keamanan (JSON Web Token)
# # generate  di : https://www.lastpass.com/features/password-generator
JWT_SECRET=rahasia_jwt_super_aman_ganti_ini

# Konfigurasi Aplikasi Frontend (Vite)
VITE_API_BASE_URL=http://localhost:5000
VITE_INSTITUTION_URL=https://fti.uksw.edu

# Google Calendar API Credentials
# Dapatkan Client ID dan API Key dari Google Cloud Console
# Pastikan API Key dibatasi (HTTP Referrer Restriction) untuk domain production
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-api-key-here

# ============================================================
# Konfigurasi Email (Nodemailer + Gmail App Password)
# ============================================================
# Langkah setup:
# 1. Login ke myaccount.google.com dengan akun Gmail pengirim
# 2. Security > 2-Step Verification (aktifkan dulu)
# 3. Security > App Passwords > buat password baru (nama: CORE FTI Mailer)
# 4. Salin 16 karakter tanpa spasi ke EMAIL_PASS
EMAIL_USER=noreply.core.fti@gmail.com
EMAIL_PASS=16_karakter_app_password_tanpa_spasi
EMAIL_FROM_NAME=TU FTI UKSW
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_TLS=true